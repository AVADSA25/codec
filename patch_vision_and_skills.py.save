# ═══════════════════════════════════════════════════════════════
# PATCH 5: Update Google OAuth scopes — re-auth needed
# ═══════════════════════════════════════════════════════════════
print("\n[5/5] Checking Google OAuth scopes...")

TOKEN_PATH = os.path.expanduser("~/.codec/google_token.json")
CREDS_PATH = os.path.expanduser("~/.codec/google_credentials.json")

# New scopes needed for Docs, Sheets, Slides, Tasks
REQUIRED_SCOPES = [
    "https://www.googleapis.com/auth/gmail.readonly",
    "https://www.googleapis.com/auth/calendar.readonly",
    "https://www.googleapis.com/auth/drive.readonly",
    "https://www.googleapis.com/auth/documents.readonly",
    "https://www.googleapis.com/auth/spreadsheets.readonly",
    "https://www.googleapis.com/auth/presentations.readonly",
    "https://www.googleapis.com/auth/tasks.readonly",
]

import json as json_mod

try:
    with open(TOKEN_PATH) as f:
        token_data = json_mod.load(f)
    current_scopes = token_data.get("scopes", [])
    # Also check the 'scope' field (some formats use space-separated string)
    if not current_scopes and "scope" in token_data:
        current_scopes = token_data["scope"].split()

    missing = [s for s in REQUIRED_SCOPES if s not in current_scopes]

    if missing:
        print(f"  ⚠ Missing scopes: {len(missing)}")
        for s in missing:
            short = s.split("/")[-1]
            print(f"    - {short}")
        print()
        print("  ═══════════════════════════════════════════════════")
        print("  ACTION REQUIRED: Re-run Google OAuth to add new scopes.")
        print("  ═══════════════════════════════════════════════════")
        print()

        # Write a re-auth helper script
        reauth_script = f'''#!/usr/bin/env python3
"""Re-authenticate Google OAuth with expanded scopes for CODEC"""
import os, json

CREDS_PATH = os.path.expanduser("~/.codec/google_credentials.json")
TOKEN_PATH = os.path.expanduser("~/.codec/google_token.json")

SCOPES = {json_mod.dumps(REQUIRED_SCOPES, indent=4)}

# Delete old token to force re-auth
if os.path.exists(TOKEN_PATH):
    os.rename(TOKEN_PATH, TOKEN_PATH + ".backup")
    print(f"Backed up old token to {{TOKEN_PATH}}.backup")

from google_auth_oauthlib.flow import InstalledAppFlow
flow = InstalledAppFlow.from_client_secrets_file(CREDS_PATH, SCOPES)
creds = flow.run_local_server(port=0)

with open(TOKEN_PATH, "w") as f:
    f.write(creds.to_json())

print(f"\\n\\u2705 New token saved with {{len(SCOPES)}} scopes!")
print("Skills now available: Gmail, Calendar, Drive, Docs, Sheets, Slides, Tasks")
'''
        reauth_path = os.path.join(REPO, "reauth_google.py")
        with open(reauth_path, "w") as f:
            f.write(reauth_script)
        os.chmod(reauth_path, 0o755)
        print(f"  ✓ Created {reauth_path}")
        print("  Run: cd ~/codec-repo && python3 reauth_google.py")
        print("  (This will open a browser for Google login)")
    else:
        print("  ✓ All required scopes already present!")
except FileNotFoundError:    
    print("  ⚠ Token file not found — run reauth_google.py after creating credentials")

